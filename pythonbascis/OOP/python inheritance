# base class
class Animal:
    def eat(self):
        print("I can eat")

# the Dog class is derived from Animal
# notice Animal inside ()        
class Dog(Animal):
    def bark(self):
        print("I can bark")


# object of the dog class
dog1 = Dog()

# call the bark() method (of Dog)
dog1.bark()

# call the eat() method (of Animal)
dog1.eat()
